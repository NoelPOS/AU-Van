# Core required (app boot/auth/db)
MONGODB_URI=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LINE / LIFF
# At least one of these is needed for LIFF token verification (prefer LINE_LIFF_CHANNEL_ID)
NEXT_PUBLIC_LINE_LIFF_ID=
LINE_LIFF_CHANNEL_ID=

# LINE bot/webhook features
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_RICH_MENU_ID=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@auvan.com

# Booking/reminder behavior
SEAT_LOCK_TIMEOUT_MS=300000
REMINDER_WORKER_SECRET=
REMINDER_MAX_ATTEMPTS=5
REMINDER_SCHEDULE_MODE=daily_batch
REMINDER_BATCH_HOUR_UTC=1

# Vercel cron auth
CRON_SECRET=
